# IT Cockpit Backend — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to source control.

# ── App ──────────────────────────────────────────────────────────
APP_ENV=local       # Set to "production" when deploying

# ── Database (Phase 3) ───────────────────────────────────────────
# Local SQLite (default, no setup needed):
DATABASE_URL=sqlite+aiosqlite:///./itcockpit_dev.db

# MS SQL Server (ManageEngine production DB):
# DATABASE_URL=mssql+aioodbc://USERNAME:PASSWORD@SERVER_NAME/SDPDB?driver=ODBC+Driver+17+for+SQL+Server

# ── Azure AD (Phase 4 — Teams Authentication) ────────────────────
AZURE_TENANT_ID=your-tenant-id-here
AZURE_CLIENT_ID=your-client-id-here
AZURE_CLIENT_SECRET=your-client-secret-here
